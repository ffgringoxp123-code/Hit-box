local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local RunService = game:GetService("RunService")
local noclip = false

-- GUI
local ScreenGui = Instance.new("ScreenGui", player.PlayerGui)
ScreenGui.Name = "MimicKtlGUI"

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 160, 0, 80)
Frame.Position = UDim2.new(0, 20, 0.6, 0)
Frame.BackgroundColor3 = Color3.fromRGB(10, 0, 0)
Frame.BorderSizePixel = 2
Frame.BorderColor3 = Color3.fromRGB(180, 0, 0)
Frame.Active = true
Frame.Draggable = true
Frame.Name = "Mimic Ktl"

-- Bo góc
local UICorner = Instance.new("UICorner", Frame)
UICorner.CornerRadius = UDim.new(0, 8)

-- Title
local TitleLabel = Instance.new("TextLabel", Frame)
TitleLabel.Size = UDim2.new(1, 0, 0, 20)
TitleLabel.Position = UDim2.new(0, 0, 0, 0)
TitleLabel.Text = "Mimic Ktl"
TitleLabel.TextScaled = true
TitleLabel.Font = Enum.Font.GothamBold
TitleLabel.BackgroundTransparency = 1
TitleLabel.TextColor3 = Color3.fromRGB(200, 0, 0)
TitleLabel.BorderSizePixel = 0

-- Button
local Button = Instance.new("TextButton", Frame)
Button.Size = UDim2.new(0, 120, 0, 36)
Button.Position = UDim2.new(0, 20, 0, 30)
Button.Text = "NOCLIP OFF"
Button.TextScaled = true
Button.Font = Enum.Font.GothamBold
Button.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
Button.TextColor3 = Color3.fromRGB(255, 50, 50)
Button.BorderSizePixel = 2
Button.BorderColor3 = Color3.fromRGB(180, 0, 0)

-- Bo góc button
local BtnCorner = Instance.new("UICorner", Button)
BtnCorner.CornerRadius = UDim.new(0, 6)

-- Drop shadow effect cho frame
local Shadow = Instance.new("Frame", Frame)
Shadow.Size = UDim2.new(1, 4, 1, 4)
Shadow.Position = UDim2.new(0, -2, 0, -2)
Shadow.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
Shadow.BackgroundTransparency = 0.7
Shadow.BorderSizePixel = 0
Shadow.ZIndex = -1

-- Function
RunService.Stepped:Connect(function()
    if noclip and char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = false
            end
        end
    end
end)

Button.MouseButton1Click:Connect(function()
    noclip = not noclip
    if noclip then
        Button.Text = "NOCLIP ON"
        Button.BackgroundColor3 = Color3.fromRGB(80, 0, 0)
        Button.TextColor3 = Color3.fromRGB(255, 0, 0)
        Frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
    else
        Button.Text = "NOCLIP OFF"
        Button.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
        Button.TextColor3 = Color3.fromRGB(255, 50, 50)
        Frame.BorderColor3 = Color3.fromRGB(180, 0, 0)
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CanCollide = true
            end
        end
    end
end)
