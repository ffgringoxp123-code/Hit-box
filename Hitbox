-- Vòng lặp hiệu ứng chuyển động
task.spawn(function()
    while task.wait(0.05) do
        pcall(function()
            -- Giọt máu chảy xuống
            for _, data in pairs(BloodDrips) do
                if data.Frame and data.Frame.Parent then
                    local currentY = data.Frame.Position.Y.Offset
                    local newY = currentY + data.Speed
                    if newY > 220 then
                        newY = -20
                        data.Frame.Size = UDim2.new(0, math.random(2, 5), 0, math.random(8, 20))
                    end
                    data.Frame.Position = UDim2.new(0, data.X, 0, newY)
                end
            end
            
            -- Mắt ma chuyển động
            for _, data in pairs(FloatingEyes) do
                if data.Frame and data.Frame.Parent then
                    local cf = data.Frame.Position
                    local newX = cf.X.Offset + math.sin(tick() * data.Speed) * 0.5
                    local newY = cf.Y.Offset + math.cos(tick() * data.Speed * 0.7) * 0.3
                    data.Frame.Position = UDim2.new(0, newX, 0, newY)
                end
            end
            
            -- Glitch nhấp nháy
            for _, data in pairs(GlitchLines) do
                if data.Frame and data.Frame.Parent then
                    local trans = data.Frame.BackgroundTransparency
                    if math.random() > 0.95 then
                        data.Frame.BackgroundTransparency = 0.1 + math.random() * 0.5
                        data.Frame.Size = UDim2.new(0, math.random(30, 120), 0, math.random(1, 3))
                    end
                end
            end
        end)
    end
end)

