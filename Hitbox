PillClick.Parent = MainFrame

-- Logic Giao diện
local isMinimized = false

ToggleBtn.MouseButton1Click:Connect(function()
    HitboxSettings.Enabled = not HitboxSettings.Enabled
    if HitboxSettings.Enabled then
        ToggleBtn.Text = "Trạng thái: ĐANG BẬT"
        ToggleBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        ToggleBtn.Text = "Trạng thái: TẮT"
        ToggleBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

-- Cập nhật hitbox bằng TextBox (cho phép nhập số tùy thích)
SizeInput.FocusLost:Connect(function()
    local num = tonumber(SizeInput.Text)
    if num then
        HitboxSettings.Size = num
    else
        SizeInput.Text = tostring(HitboxSettings.Size) -- Trả về số cũ nếu nhập chữ
    end
end)

-- Logic Cuộn lại thành hình tròn dài (Pill Shape)
local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

MinimizeBtn.MouseButton1Click:Connect(function()
    isMinimized = true
    ContentFrame.Visible = false
    
    -- Cuộn lại thành hình tròn dài ngang và bay lên giữa góc trên
    local shrinkTween = TweenService:Create(MainFrame, tweenInfo, {
        Size = UDim2.new(0, 140, 0, 40),
        Position = UDim2.new(0.5, -70, 0, 20) -- Cố định ở giữa phía trên
    })
    
    shrinkTween:Play()
    shrinkTween.Completed:Wait()
    
    PillText.Visible = true
    PillClick.Visible = true
end)

PillClick.MouseButton1Click:Connect(function()
    isMinimized = false
    PillText.Visible = false
    PillClick.Visible = false
    
    local expandTween = TweenService:Create(MainFrame, tweenInfo, {
        Size = UDim2.new(0, 300, 0, 200),
        Position = UDim2.new(0.5, -150, 0.5, -100)
    })
    
    expandTween:Play()
    expandTween.Completed:Wait()
    
    ContentFrame.Visible = true
end)

task.spawn(function()
    while task.wait(1) do
        if HitboxSettings.Enabled then
            pcall(function()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") then
                        local character = obj.Parent
                        
                        -- Chặn target vào quái đã chết (ghost) và bỏ qua người chơi
                        if obj.Health > 0 and not Players:GetPlayerFromCharacter(character) then
                            local hrp = character:FindFirstChild("HumanoidRootPart")
                            
                            if hrp then
                                hrp.Size = Vector3.new(HitboxSettings.Size, HitboxSettings.Size, HitboxSettings.Size)
                                hrp.Transparency = HitboxSettings.Transparency
                                hrp.Color = HitboxSettings.Color
                                hrp.Material = Enum.Material.Neon
                                hrp.CanCollide = false
                            end
                        end
                    end
                end
            end)
        end
    end
end)

