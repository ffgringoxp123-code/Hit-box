-- ====== LOGIC TOGGLE ======
local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

local function UpdateToggleUI()
    if HitboxSettings.Enabled then
        ToggleKnob:TweenPosition(UDim2.new(0, 42, 0, 2), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
        ToggleText.Text = "ON"
        ToggleText.TextColor3 = Color3.fromRGB(200, 0, 0)
        ToggleBg.BackgroundColor3 = Color3.fromRGB(50, 5, 5)
        ToggleBg.BorderColor3 = Color3.fromRGB(200, 0, 0)
        ToggleKnob.BackgroundColor3 = Color3.fromRGB(220, 0, 0)
        StatusLight.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        StatusText.Text = "ACTIVE"
        StatusText.TextColor3 = Color3.fromRGB(255, 0, 0)
        
        -- Hiệu ứng nhấp nháy đèn
        spawn(function()
            while HitboxSettings.Enabled and StatusLight do
                StatusLight:TweenSize(UDim2.new(0, 12, 0, 12), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
                task.wait(0.3)
                StatusLight:TweenSize(UDim2.new(0, 8, 0, 8), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
                task.wait(0.3)
            end
        end)
    else
        ToggleKnob:TweenPosition(UDim2.new(0, 2, 0, 2), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.15, true)
        ToggleText.Text = "OFF"
        ToggleText.TextColor3 = Color3.fromRGB(120, 30, 30)
        ToggleBg.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
        ToggleBg.BorderColor3 = Color3.fromRGB(100, 0, 0)
        ToggleKnob.BackgroundColor3 = Color3.fromRGB(80, 0, 0)
        StatusLight.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
        StatusText.Text = "INACTIVE"
        StatusText.TextColor3 = Color3.fromRGB(80, 0, 0)
        StatusLight.Size = UDim2.new(0, 8, 0, 8)
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    HitboxSettings.Enabled = not HitboxSettings.Enabled
    UpdateToggleUI()
end)

