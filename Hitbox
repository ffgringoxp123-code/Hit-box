-- Lưu trữ hitbox đã thay đổi để restore khi tắt
local ChangedParts = {}

-- Hàm reset hitbox quái về mặc định
local function ResetAllHitboxes()
    for part, origSize in pairs(ChangedParts) do
        if part and part.Parent then
            part.Size = origSize
            part.Transparency = 1
            part.Color = Color3.fromRGB(255, 255, 255)
            part.Material = Enum.Material.Plastic
        end
    end
    table.clear(ChangedParts)
end

