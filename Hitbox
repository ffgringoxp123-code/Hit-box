task.spawn(function()
    while task.wait(0.15) do
        if HitboxSettings.Enabled then
            pcall(function()
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") then
                        local character = obj.Parent
                        local hrp = character:FindFirstChild("HumanoidRootPart")
                        
                        -- CHỈ quái: health > 0, KHÔNG player, có HRP
                        if obj.Health > 0 and hrp and not Players:GetPlayerFromCharacter(character) then
                            local currentSize = hrp.Size.X
                            local targetSize = HitboxSettings.Size
                            
                            -- Lưu kích thước gốc nếu chưa có
                            if not ChangedParts[hrp] then
                                ChangedParts[hrp] = hrp.Size
                            end
                            
                            -- Chỉ thay đổi nếu khác
                            if math.abs(currentSize - targetSize) > 0.5 then
                                hrp.Size = Vector3.new(targetSize, targetSize, targetSize)
                            end
                            
                            hrp.Transparency = 0.6
                            hrp.Color = Color3.fromRGB(255, 0, 0)
                            hrp.Material = Enum.Material.Neon
                            hrp.CanCollide = false
                        end
                    end
                end
            end)
        end
    end
end)

